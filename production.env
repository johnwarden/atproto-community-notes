# Production Environment Variables for Community Notes Service
# Used by both manual deployment (just deploy) and CI/CD (GitHub Actions)

# App Configuration
NODE_ENV=production
LOG_ENABLED=true
LOG_LEVEL=debug
LOG_DESTINATION=/dev/stdout

# AT Protocol Configuration
