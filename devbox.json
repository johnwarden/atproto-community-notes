{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.14.2/.schema/devbox.schema.json",
  "packages": [
    "git",
    "nodejs_22", // pin to Node 22 LTS (compatible with better-sqlite3@10.x)
    "yarn", // node-gyp needs Python
    "cmake", // some libs still use it
    "pkg-config", // so better-sqlite3 can locate sqlite3
    "sqlite", // the sqlite3 headers & libs
    "clang", // a GCC/Clang that supports C++20
    "llvm",
    "cloc@latest",
    "pnpm@10.14.0",
    "corepack_24",
    "python311@latest",
    "python311Packages.setuptools@latest",
    "just@latest",
    "process-compose@latest",
    "flyctl@latest",
  ],
  "shell": {
    "init_hook": ["pnpm install --frozen-lockfile"],
  },
}
