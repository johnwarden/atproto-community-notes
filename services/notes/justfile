# Community Notes Service Management Commands
# Usage: just <command>

set dotenv-load := true

# Default recipe - show available commands
default:
    @just --list

# Check environment variables (non-sensitive only)
env:
    @echo "🔧 Environment variables status:"
    @echo "NODE_ENV: ${NODE_ENV:-'not set'}"
    @echo "PORT: ${PORT:-'not set'}"
    @echo "INTERNAL_API_PORT: ${INTERNAL_API_PORT:-'not set'}"
    @echo "INTERNAL_API_HOST: ${INTERNAL_API_HOST:-'not set (will use FLY_PRIVATE_IPV6)'}"
    @echo "PDS_URL: ${PDS_URL:-'not set'}"
    @echo "DB_PATH: ${DB_PATH:-'not set'}"
    @echo "REPO_DID: ${REPO_DID:-'not set'}"
    @echo "FEEDGEN_DOCUMENT_DID: ${FEEDGEN_DOCUMENT_DID:-'not set'}"
    @echo "LABELER_DID: ${LABELER_DID:-'not set'}"
    @echo "LABELER_URL: ${LABELER_URL:-'not set'}"


# One-command health check of everything
status: health fly-status

# Check service health endpoints
health:
    @echo "\n🏥 Checking service health..."
    @curl -s "https://notes.fly.dev/health" | jq . || echo "Service: ❌ Not responding"


# === LiteFS Setup ===

# Set up LiteFS volume for Notes service (required for shared database)
setup-litefs-volume:
    @echo "💾 Setting up LiteFS volume for Notes service..."
    @echo "📊 Creating 10GB volume in sjc region..."
    fly volumes create litefs --region sjc --size 10
    @echo "✅ LiteFS volume created successfully!"
    @echo "💡 Volume will be mounted at /litefs in the container"

# Check LiteFS status
litefs-status:
    @echo "🔍 Checking LiteFS status..."
    fly ssh console --command "litefs status"

# Check database status
db-status:
    @echo "🔍 Checking database status..."
    fly ssh console --command "ls -la /litefs/ && sqlite3 /litefs/notes.db 'SELECT COUNT(*) FROM sqlite_master;'"

# === Deployment & Management ===

# Set up SSL certificate
setup-cert:
    fly certs add notes.fly.dev

# Set secrets interactively (SECRETS ONLY - never saved to files)
setup-secrets:
    #!/bin/zsh
    source ./secrets.sh
    fly secrets set AID_SALT="$AID_SALT"
    fly secrets set REPO_PASSWORD="$REPO_PASSWORD"
    echo "✅ All secrets configured securely for Notes service!"

# Deploy Notes service to Fly.io
deploy:
    @echo "🚀 Deploying Notes service..."
    fly deploy \
        --env NODE_ENV=${NODE_ENV} \
        --env LOG_ENABLED=true \
        --env LOG_LEVEL=${LOG_LEVEL} \
        --env LOG_DESTINATION=${LOG_DESTINATION} \
        --env INTERNAL_API_HOST=${INTERNAL_API_HOST} \
        --env PDS_URL=${PDS_URL} \
        --env LABELER_URL=${LABELER_URL} \
        --env DB_PATH=${DB_PATH} \
        --env REPO_DID=${REPO_DID} \
        --env FEEDGEN_DOCUMENT_DID=${FEEDGEN_DOCUMENT_DID} \
        --env LABELER_DID=${LABELER_DID}

# Deploy with custom environment variables (for advanced usage)
deploy-env *ARGS:
    @echo "🚀 Deploying Notes service with custom environment..."
    fly deploy {{ARGS}}

# Complete Fly.io deployment setup for Notes service
fly-setup:
    @echo "🚀 Complete Fly.io deployment setup for Notes service..."
    @echo "1️⃣ Creating Fly.io app..."
    fly apps create notes
    @echo "2️⃣ Setting secrets from environment..."
    just setup-secrets
    @echo "3️⃣ Creating LiteFS volume..."
    just setup-litefs-volume
    @echo "4️⃣ Deploying application..."
    just deploy
    @echo "✅ Notes service deployment complete!"
    @echo "🔗 Your Community Notes service is available at: https://notes.fly.dev"

# Restart the Fly.io application
restart:
    fly app restart

# Check Fly.io app status
fly-status:
    fly status

# Open Fly.io dashboard
fly-dashboard:
    fly dashboard


# Show recent application logs
logs:
    fly logs


# === Database Management ===

# Connect to production notes database via SSH
db-connect:
    @echo "🗄️ Connecting to production notes database..."
    fly ssh console --command "sqlite3 ${DB_PATH}"

# Show recent score events
db-score-events:
    @echo "🗄️ Recent score events..."
    fly ssh console --command "sqlite3 ${DB_PATH} 'SELECT * FROM scoreEvent ORDER BY createdAt DESC LIMIT 10;'"

# Show pending labels
db-pending-labels:
    @echo "🗄️ Pending labels..."
    fly ssh console --command "sqlite3 ${DB_PATH} 'SELECT * FROM pendingLabels ORDER BY createdAt DESC LIMIT 10;'"

# Show recent proposals
db-proposals:
    @echo "🗄️ Recent proposals..."
    fly ssh console --command "sqlite3 ${DB_PATH} 'SELECT uri, indexedAt FROM record WHERE collection = \"social.pmsky.proposal\" ORDER BY indexedAt DESC LIMIT 10;'"

# Show recent ratings
db-ratings:
    @echo "🗄️ Recent ratings..."
    fly ssh console --command "sqlite3 ${DB_PATH} 'SELECT uri, indexedAt FROM record WHERE collection = \"social.pmsky.rating\" ORDER BY indexedAt DESC LIMIT 10;'"
