# Community Notes Service Management Commands
# Usage: just <command>


import "production-vars.just"

set dotenv-load := false

help:
    @just --list --unsorted

# Default recipe - show available commands
default:
    @just --list



PORT := "8080"
INTERNAL_API_PORT := "8081"

# Set up internal endpoint for local development
INTERNAL_ENDPOINT := "http://atproto-notes-api.internal:8081"

HOSTNAME := "api.c10t.es"

# Check environment variables (non-sensitive only)
prod-env:
    @echo "🔧 Environment variables status:"
    @echo "NODE_ENV: {{NODE_ENV}}"
    @echo "PORT: {{PORT}}"
    @echo "INTERNAL_API_PORT: {{INTERNAL_API_PORT}}"
    @echo "PDS_URL: {{PDS_URL}}"
    @echo "DB_PATH: {{DB_PATH}}"
    @echo "REPO_DID: {{REPO_DID}}"
    @echo "FEEDGEN_DOCUMENT_DID: {{FEEDGEN_DOCUMENT_DID}}"
    @echo "LABELER_DID: {{LABELER_DID}}"
    @echo "LABELER_URL: {{LABELER_URL}}"
    @echo "HOSTNAME: {{HOSTNAME}}"
    @echo "LOG_ENABLED: {{LOG_ENABLED}}"
    @echo "LOG_LEVEL: {{LOG_LEVEL}}"
    @echo "LOG_DESTINATION: {{LOG_DESTINATION}}"



# One-command health check of everything
status: health fly-status

# Check service health endpoints
health:
    @curl -s "https://atproto-notes-api.fly.dev/health" | jq . || echo "Service: ❌ Not responding"
    @curl -s "{{INTERNAL_ENDPOINT}}/internal/_health" | jq . || echo "❌ Internal API not responding"

# === Internal API Testing ===

# Test internal /score endpoint with sample data
test-score-endpoint:
    @echo "🧪 Testing internal /score endpoint..."
    @curl -s -X POST "{{INTERNAL_ENDPOINT}}/score" \
        -H "Content-Type: application/json" \
        -d '{"proposalUri": "at://did:example/social.pmsky.proposal/test", "status": "rated_helpful", "score": 0.8}' \
        | jq . || echo "❌ Score endpoint not responding"

# Set score for a specific proposal (interactive)
set-score PROPOSAL_URI STATUS SCORE:
    @echo "📊 Setting score for proposal..."
    @curl -s -X POST "{{INTERNAL_ENDPOINT}}/score" \
        -H "Content-Type: application/json" \
        -d '{"proposalUri": "{{PROPOSAL_URI}}", "status": "{{STATUS}}", "score": {{SCORE}}}' \
        | jq .



# === LiteFS Setup ===

# Set up LiteFS volume for Notes service (required for shared database)
setup-litefs-volume:
    @echo "💾 Setting up LiteFS volume for Notes service..."
    @echo "📊 Creating 10GB volume in sjc region..."
    cd ../.. && fly volumes create litefs --region sjc --size 1 
    @echo "✅ LiteFS volume created successfully!"
    @echo "💡 Volume will be mounted at /litefs in the container"

# Check LiteFS status
litefs-status:
    @echo "🔍 Checking LiteFS status..."
    cd ../.. && fly ssh console --command "litefs status"

# Check database status
db-status:
    @echo "🔍 Checking database status..."
    cd ../.. && fly ssh console --command "ls -la /litefs/ && sqlite3 /litefs/notes.db 'SELECT COUNT(*) FROM sqlite_master;'"


# === Deployment & Management ===

# Set up SSL certificate
setup-cert:
    cd ../.. && fly certs add {{HOSTNAME}}

# Set secrets interactively (SECRETS ONLY - never saved to files)
setup-secrets:
    #!/bin/zsh
    source ./secrets.sh
    cd ../.. && fly secrets set AID_SALT="$AID_SALT"
    cd ../.. && fly secrets set REPO_PASSWORD="$REPO_PASSWORD"
    echo "✅ All secrets configured securely for Notes service!"

# Deploy Notes service to Fly.io (from project root)
deploy:
    @echo "🚀 Deploying Notes service from project root..."
    cd ../.. && LOG_LEVEL=info fly deploy \
        --config fly.toml \
        --env NODE_ENV={{NODE_ENV}} \
        --env LOG_ENABLED={{LOG_ENABLED}} \
        --env LOG_LEVEL={{LOG_LEVEL}} \
        --env LOG_DESTINATION="{{LOG_DESTINATION}}" \
        --env PDS_URL="{{PDS_URL}}" \
        --env LABELER_URL={{LABELER_URL}} \
        --env DB_PATH={{DB_PATH}} \
        --env REPO_DID={{REPO_DID}} \
        --env FEEDGEN_DOCUMENT_DID={{FEEDGEN_DOCUMENT_DID}} \
        --env LABELER_DID={{LABELER_DID}}

# Build Docker image (from project root for optimal caching)
docker-build:
    @echo "🐳 Building Docker image from project root..."
    cd ../.. && docker build -f services/notes/Dockerfile --progress=plain -t community-notes-service .

# Complete Fly.io deployment setup for Notes service
fly-setup:
    @echo "🚀 Complete Fly.io deployment setup for Notes service..."
    @echo "Creating Fly.io app..."
    cd ../.. && fly apps create notes
    @echo "Setting secrets from environment..."
    cd ../.. && just setup-secrets
    @echo "Creating LiteFS volume..."
    cd ../.. && just setup-litefs-volume
    @echo "SEtting up certs..."
    cd ../.. && just setup-certs
    @echo "Deploying application..."
    cd ../.. && just notes-deploy
    @echo "✅ Notes service deployment complete!"
    @echo "🔗 Your Community Notes service is available at: https://atproto-notes-api.fly.dev"

# Restart the Fly.io application
restart-app:
    fly app restart

# Check Fly.io app status
fly-status:
    fly status

# Open Fly.io dashboard
fly-dashboard:
    fly dashboard


# Show recent live application logs
app-logs:
    cd ../.. && LOG_LEVEL=info fly logs -j \
    | jq --unbuffered -c -r 'select(.meta.Event.Provider=="app") \
        | .message \
        | (fromjson? // empty) \
        | select(.name=="notes")' \
    | node_modules/.bin/pino-pretty --colorize --translateTime 'SYS:yyyy-mm-dd HH:MM:ss.l'

scoring-logs:
    cd ../.. && LOG_LEVEL=info fly logs -j \
    | jq --unbuffered -c -r 'select(.meta.Event.Provider=="app") \
        | .message \
        | (fromjson? // empty) \
        | select(.name=="scoring")' \
    | node_modules/.bin/pino-pretty --colorize --translateTime 'SYS:yyyy-mm-dd HH:MM:ss.l'



# Show recent live HTTP logs
http-logs:
    cd ../.. && LOG_LEVEL=info fly logs -j \
    | jq --unbuffered -c -r 'select(.meta.Event.Provider=="app") \
        | .message \
        | (fromjson? // empty) \
        | select(.name=="notes:http")' \
    | node_modules/.bin/pino-pretty --colorize --translateTime 'SYS:yyyy-mm-dd HH:MM:ss.l'

# Show recent live fly.io logs
fly-logs:
    LOG_LEVEL=info cd ../.. && fly logs | awk '!/\{.*\}$/'   # drop lines that end with a JSON object

logs-tmux:
    tmux new-session \; \
      send-keys "just fly-logs" C-m \; \
      split-window -v \; \
      send-keys "just app-logs" C-m \; \
      select-pane -t 0 \; \
      split-window -h \; \
      send-keys "just http-logs" C-m \; \
      select-layout tiled


# === Database Management ===

# Connect to production notes database via SSH
db:
    @echo "🗄️ Connecting to production notes database..."
    cd ../.. && fly ssh console --command "sqlite3 {{DB_PATH}}"

