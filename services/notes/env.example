# Community Notes Service Configuration
# Rename this file to .env for production deployment
# Contains ONLY non-secret variables - secrets go in Fly.io secrets

# Service Configuration
NODE_ENV=production
PORT=8081
INTERNAL_API_PORT=8082

# if not set, the app will look for FLY_PRIVATE_IPV6 
INTERNAL_API_HOST=

# External Services
PDS_URL=https://bsky.network

# Database Configuration
# Single SQLite database for all Community Notes data (shared via LiteFS)
DB_PATH=/litefs/notes.db

# DIDs (public, not secrets)
REPO_DID=did:plc:your-production-repo-did
FEEDGEN_DOCUMENT_DID=did:plc:your-production-feedgen-did
LABELER_DID=did:plc:your-production-labeler-did

# External Labeler Service
LABELER_URL=https://labeler.example.com

# Secrets (set via fly secrets set - NOT in this file):
# AID_SALT=your-aid-generation-salt
# REPO_PASSWORD=your-repo-password
